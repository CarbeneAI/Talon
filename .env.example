# Talon SSH Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Your Kali Linux (or pentest VM) IP address
SSH_HOST=YOUR_KALI_IP

# SSH username on the pentest VM
SSH_USER=YOUR_USERNAME

# Path to your SSH private key (default uses ~/.ssh/id_ed25519)
SSH_KEY_PATH=~/.ssh/id_ed25519
